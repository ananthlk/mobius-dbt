# Origin: RAG Postgres (ingest reads from here).
# For Job UI origin dropdown: use unprefixed vars for dev, or set ORIGIN_DEV_* / ORIGIN_PROD_*.
POSTGRES_HOST=34.59.175.121
POSTGRES_PORT=5432
POSTGRES_DB=mobius_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=MobiusOS123$

# Optional: origin dev (if unset, unprefixed POSTGRES_* above = dev)
# ORIGIN_DEV_POSTGRES_HOST=...
# ORIGIN_DEV_POSTGRES_PASSWORD=...
# Optional: origin prod
# ORIGIN_PROD_POSTGRES_HOST=...
# ORIGIN_PROD_POSTGRES_PASSWORD=...

# BigQuery (mart dataset). For Job UI destination: use unprefixed for dev, or set DEST_DEV_* / DEST_PROD_*.
BQ_PROJECT=mobiusos-new
BQ_DATASET=mobius_rag_dev

# Destination: Chat Postgres (sync writes published_rag_metadata here; must match Mobius-Chat CHAT_RAG_DATABASE_URL)
CHAT_DATABASE_URL=postgresql://postgres:MobiusOS123$@34.59.175.121:5432/mobius_chat

# Vertex AI (batch index)
VERTEX_PROJECT=mobiusos-new
VERTEX_REGION=us-central1
VERTEX_INDEX_ID=2830628914034900992
VERTEX_INDEX_MODE=batch
GCS_BUCKET=mobiusos-new-vertex-index
GCS_PREFIX=chat_rag_index

# Optional: destination prod (different BQ dataset, Chat URL, Vertex index)
# DEST_PROD_BQ_DATASET=mobius_rag
# DEST_PROD_CHAT_DATABASE_URL=postgresql://...
# DEST_PROD_VERTEX_INDEX_ID=...
