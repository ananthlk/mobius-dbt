# =============================================================================
# Mobius DBT - Environment Configuration
# =============================================================================
# Uses mobius-os-dev GCP project. See mobius-config/.env.example for full reference.
# =============================================================================

# -----------------------------------------------------------------------------
# ORIGIN: RAG POSTGRES (must match mobius-rag DATABASE_URL for lexicon sync)
# -----------------------------------------------------------------------------
POSTGRES_HOST=34.135.72.145
POSTGRES_PORT=5432
POSTGRES_DB=mobius_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=MobiusDev123$
# Optional: RAG_DATABASE_URL for sync_rag_lexicon_to_chat (defaults to POSTGRES_*)

# -----------------------------------------------------------------------------
# DESTINATION: BIGQUERY
# -----------------------------------------------------------------------------
BQ_PROJECT=mobius-os-dev
BQ_LANDING_DATASET=landing_rag
BQ_DATASET=mobius_rag

# -----------------------------------------------------------------------------
# DESTINATION: CHAT POSTGRES
# -----------------------------------------------------------------------------
CHAT_DATABASE_URL=postgresql://postgres:MobiusDev123$@34.135.72.145:5432/mobius_chat

# -----------------------------------------------------------------------------
# DESTINATION: VERTEX AI VECTOR SEARCH
# -----------------------------------------------------------------------------
VERTEX_PROJECT=mobius-os-dev
VERTEX_REGION=us-central1
VERTEX_INDEX_ID=8112788326987071488
VERTEX_INDEX_ENDPOINT_ID=156370344679047168
VERTEX_INDEX_MODE=streaming

# GCS for batch index data
GCS_BUCKET=mobius-dev-vertex-index
GCS_PREFIX=chat_rag_index

# =============================================================================
# PRODUCTION DESTINATION (for Job UI "Dest: Prod")
# =============================================================================
DEST_PROD_BQ_PROJECT=mobiusos-new
DEST_PROD_BQ_LANDING_DATASET=landing_rag
DEST_PROD_BQ_DATASET=mobius_rag
DEST_PROD_CHAT_DATABASE_URL=postgresql://postgres:YOUR_PROD_PASSWORD@/mobius_chat?host=/cloudsql/mobiusos-new:us-central1:mobius-platform-db
DEST_PROD_VERTEX_PROJECT=mobiusos-new
DEST_PROD_VERTEX_REGION=us-central1
DEST_PROD_VERTEX_INDEX_ID=2830628914034900992
DEST_PROD_VERTEX_INDEX_ENDPOINT_ID=4513040034206580736
DEST_PROD_VERTEX_INDEX_MODE=streaming
DEST_PROD_GCS_BUCKET=mobiusos-new-vertex-index

# =============================================================================
# STAGING DESTINATION (for Job UI "Dest: Staging")
# =============================================================================
DEST_STAGING_BQ_PROJECT=mobius-staging-mobius
DEST_STAGING_BQ_LANDING_DATASET=landing_rag
DEST_STAGING_BQ_DATASET=mobius_rag
DEST_STAGING_CHAT_DATABASE_URL=postgresql://mobius_app:YOUR_STAGING_PASSWORD@127.0.0.1:5433/mobius_chat
DEST_STAGING_VERTEX_PROJECT=mobius-staging-mobius
DEST_STAGING_VERTEX_REGION=us-central1
DEST_STAGING_VERTEX_INDEX_ENDPOINT_ID=6304346785993195520
DEST_STAGING_VERTEX_INDEX_MODE=streaming
DEST_STAGING_GCS_BUCKET=mobius-rag-uploads-staging
